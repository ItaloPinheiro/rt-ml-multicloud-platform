{
  "uid": "model-performance",
  "title": "2. Model Performance",
  "panels": [
    {
      "type": "timeseries",
      "title": "Prediction Throughput",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(ml_predictions_total[5m]))",
          "legendFormat": "requests/sec",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Prediction Latency",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ml_prediction_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ml_prediction_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ml_prediction_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    },
    {
      "type": "piechart",
      "title": "Success vs Error",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(increase(ml_predictions_total{status=\"success\"}[$__range])) or vector(0)",
          "legendFormat": "Success"
        },
        {
          "expr": "sum(increase(ml_predictions_total{status=\"error\"}[$__range])) or vector(0)",
          "legendFormat": "Error"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "pieType": "pie",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "type": "stat",
      "title": "Models Loaded",
      "gridPos": {
        "x": 8,
        "y": 8,
        "w": 4,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum(ml_model_loads_total)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(ml_predictions_total{status=\"error\"}[5m]))",
          "legendFormat": "Prediction Errors",
          "refId": "A"
        },
        {
          "expr": "sum(rate(ml_model_loads_total{status=\"error\"}[5m]))",
          "legendFormat": "Model Load Errors",
          "refId": "B"
        },
        {
          "expr": "sum(rate(ml_api_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "HTTP 5xx",
          "refId": "C"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 36,
  "timezone": "browser",
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "model_name",
        "type": "query",
        "label": "Model",
        "query": "label_values(ml_predictions_total, model_name)",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  }
}